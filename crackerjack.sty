% ============================================================
%  crackerjack.sty
%  INTELLIGENCE — LaTeX Theme
%  Space Grotesk headings · DM Mono body
%  Warm paper tone · Classified red accents
%  Requires LuaLaTeX + fontspec
% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{crackerjack}[2026/04/12 Crackerjack Codebreaking Guide Style]

% ── Colour palette ──────────────────────────────────────────
\RequirePackage{xcolor}
\definecolor{ink}{HTML}{0a0c10}
\definecolor{paper}{HTML}{f4f1eb}
\definecolor{offwhite}{HTML}{e8e4dc}
\definecolor{accent}{HTML}{c8102e}
\definecolor{steel}{HTML}{4a5568}
\definecolor{muted}{HTML}{7a8494}
\definecolor{codebg}{HTML}{0a0c10}
\definecolor{codefg}{HTML}{e2ddd5}

% ── Page geometry ────────────────────────────────────────────
\RequirePackage[
  a4paper,
  top=2.8cm, bottom=3cm,
  left=3cm,  right=3cm,
  headheight=14pt
]{geometry}

% ── Page colour — set inside document to avoid literal output ─
\RequirePackage{pagecolor}
\AtBeginDocument{%
  \pagecolor{paper}%
  \color{ink}%
}

% ── Fonts ────────────────────────────────────────────────────
\RequirePackage{fontspec}

% Body — DM Mono
\IfFontExistsTF{DM Mono}{
  \setmainfont{DM Mono}[
    UprightFont = *-Regular,
    ItalicFont  = *-Italic,
    BoldFont    = *-Medium,
    Scale       = 0.92
  ]
  \setmonofont{DM Mono}[
    UprightFont = *-Regular,
    ItalicFont  = *-Italic,
    BoldFont    = *-Medium,
    Scale       = 0.92
  ]
}{
  \IfFontExistsTF{Courier Prime}{
    \setmainfont{Courier Prime}[Scale=0.93]
    \setmonofont{Courier Prime}[Scale=0.93]
  }{
    \setmainfont{Latin Modern Mono}[Scale=0.92]
    \setmonofont{Latin Modern Mono}[Scale=0.92]
  }
}

% Headings — Space Grotesk
\IfFontExistsTF{Space Grotesk}{
  \newfontfamily\headingfont{Space Grotesk}[
    UprightFont = *-Bold,
    BoldFont    = *-ExtraBold,
    Scale       = 1.0
  ]
}{
  \IfFontExistsTF{Fira Sans}{
    \newfontfamily\headingfont{Fira Sans}[BoldFont=*-Bold]
  }{
    \newfontfamily\headingfont{Latin Modern Sans}
  }
}

% ── Paragraph & line spacing ─────────────────────────────────
\RequirePackage{parskip}
\setlength{\parskip}{0.7em}
\setlength{\parindent}{0pt}
\RequirePackage{setspace}
\setstretch{1.25}

% ── Hyperlinks ────────────────────────────────────────────────
\RequirePackage{hyperref}
\hypersetup{
  colorlinks = true,
  urlcolor   = accent,
  linkcolor  = accent,
  citecolor  = steel,
  pdfborder  = {0 0 0}
}

% ── Heading styles ────────────────────────────────────────────
\RequirePackage{titlesec}

% Chapter: Space Grotesk, double red rule underneath
\titleformat{\chapter}[block]
  {\headingfont\LARGE\bfseries\color{ink}}
  {}
  {0pt}
  {}
  [{\color{accent}\vspace{0.3em}\hrule height 2.5pt\vspace{1.5pt}%
    \hrule height 0.5pt}]
\titlespacing*{\chapter}{0pt}{0pt}{1.4em}

% Section: red left bar, uppercase
\titleformat{\section}[block]
  {\headingfont\large\bfseries\color{ink}\MakeUppercase}
  {}
  {0pt}
  {\leavevmode\llap{\color{accent}\rule[-2pt]{3pt}{1.1em}\hspace{6pt}}}
\titlespacing*{\section}{0pt}{1.6em}{0.5em}

% Subsection: muted uppercase
\titleformat{\subsection}
  {\headingfont\normalsize\bfseries\color{muted}\MakeUppercase}
  {}
  {0pt}
  {}
\titlespacing*{\subsection}{0pt}{1.2em}{0.3em}

% ── Header / footer ───────────────────────────────────────────
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\footnotesize\color{muted}Crackerjack}
\fancyhead[R]{\footnotesize\color{muted}\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\headrule}{{\color{accent}\hrule width\headwidth height 0.4pt}}
\fancyfoot{}

% No header on chapter-opening and special pages
\fancypagestyle{plain}{
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
}

% ── Epigraph ──────────────────────────────────────────────────
\RequirePackage{epigraph}
\setlength{\epigraphwidth}{0.62\textwidth}
\setlength{\epigraphrule}{0pt}

% Double left bar (accent + neutral), italic body, muted attribution
\renewcommand{\epigraph}[2]{%
  \vspace{1em}%
  \noindent
  \begin{minipage}{\epigraphwidth}%
    {\color{accent}\rule[-4pt]{0.8pt}{\dimexpr\baselineskip + 1.2em}}%
    \hspace{3pt}%
    {\color{ink!25}\rule[-4pt]{0.8pt}{\dimexpr\baselineskip + 1.2em}}%
    \hspace{8pt}%
    \begin{minipage}{\dimexpr\epigraphwidth - 20pt}%
      {\color{steel}\itshape #1}\par
      \vspace{0.35em}%
      {\footnotesize\upshape\color{muted}\MakeUppercase{#2}}%
    \end{minipage}%
  \end{minipage}%
  \vspace{1em}\par
}

% ── tcolorbox ────────────────────────────────────────────────
\RequirePackage[most]{tcolorbox}

% ── Code blocks ──────────────────────────────────────────────
% Usage: \begin{codeblock} ... \end{codeblock}
\newtcolorbox{codeblock}{
  colback   = codebg,
  colframe  = accent,
  colupper  = codefg,
  fontupper = \small\ttfamily,
  boxrule   = 0pt,
  leftrule  = 3pt,
  arc       = 0pt,
  outer arc = 0pt,
  left      = 8pt, right  = 8pt,
  top       = 6pt, bottom = 6pt,
  enhanced
}

% Inline code
% Usage: \code{text}
\newcommand{\code}[1]{{\ttfamily\small\textcolor{accent}{#1}}}

% ── Callout boxes ─────────────────────────────────────────────
% Usage: \begin{callout}[Title] ... \end{callout}
\newtcolorbox{callout}[1][Note]{
  colback   = offwhite,
  colframe  = accent,
  coltitle  = accent,
  fonttitle = \headingfont\small\bfseries\MakeUppercase,
  boxrule   = 0pt,
  leftrule  = 4pt,
  arc       = 0pt,
  outer arc = 0pt,
  title     = {#1},
  left      = 8pt, right  = 8pt,
  top       = 6pt, bottom = 6pt,
  enhanced
}

% ── Block quotes ──────────────────────────────────────────────
% Usage: \begin{blockq} ... \end{blockq}
\newenvironment{blockq}{%
  \vspace{0.5em}%
  \noindent
  \hspace{-1.4em}%
  {\color{accent}\rule[-2pt]{3pt}{\baselineskip}}%
  \hspace{6pt}%
  \begin{minipage}{\dimexpr\linewidth - 12pt}%
  \itshape\color{steel}%
}{%
  \end{minipage}%
  \vspace{0.5em}\par
}

% ── XKCD chapter comic ────────────────────────────────────────
% Places a comic at the end of a chapter with caption and URL.
% Usage: \chaptercomic{xkcd/filename.png}{Comic title}{https://xkcd.com/NNN}
%
% Example in a chapter tex file:
%   \chaptercomic{xkcd/221.png}{RFC 2229}{https://xkcd.com/221}
\RequirePackage{graphicx}
\newcommand{\chaptercomic}[3]{%
  \vspace{2em}%
  \begin{center}%
    {\color{accent}\hrule height 0.5pt}\vspace{1em}%
    \includegraphics[width=0.82\linewidth]{#1}\par
    \vspace{0.6em}%
    {\small\color{muted}\itshape #2}\par
    \vspace{0.2em}%
    {\footnotesize\color{muted}\ttfamily\href{#3}{#3}}\par
    \vspace{1em}%
    {\color{accent}\hrule height 0.5pt}%
  \end{center}%
  \vspace{1em}%
}

% ── Tables ────────────────────────────────────────────────────
\RequirePackage{booktabs}
\RequirePackage{colortbl}
\arrayrulecolor{ink}
\setlength{\arrayrulewidth}{0.5pt}

% ── Abstract — full page, vertically centred ─────────────────
\renewenvironment{abstract}{%
  \clearpage
  \thispagestyle{empty}%
  \null\vfill
  \begin{center}%
    {\headingfont\footnotesize\bfseries\color{muted}\MakeUppercase{Abstract}}\par
    \vspace{0.9em}%
    {\color{accent}\rule{0.78\textwidth}{0.5pt}}\par
    \vspace{0.6em}%
    \begin{minipage}{0.78\textwidth}%
      \begin{tcolorbox}[
        colback  = offwhite,
        colframe = ink,
        boxrule  = 0pt,
        leftrule = 2.5pt,
        arc      = 0pt,
        left = 14pt, right  = 14pt,
        top  = 12pt, bottom = 12pt,
        enhanced
      ]%
      \normalsize\itshape\color{steel}%
}{%
      \end{tcolorbox}%
    \end{minipage}\par
    \vspace{0.6em}%
    {\color{accent}\rule{0.78\textwidth}{0.5pt}}%
  \end{center}%
  \vfill\null
  \clearpage
}

% ── Title page ────────────────────────────────────────────────
\renewcommand{\maketitle}{%
  \begin{titlepage}%
    \thispagestyle{empty}%
    \begin{center}%
      \vspace*{3cm}%
      {\color{accent}\rule{\linewidth}{2.5pt}}\par
      {\color{ink}\rule{\linewidth}{0.8pt}}\par
      \vspace{1.4cm}%
      {\headingfont\fontsize{42}{48}\selectfont\bfseries\color{ink}
        Don't Panic}\par
      \vspace{0.5cm}%
      {\headingfont\large\bfseries\color{muted}%
        \MakeUppercase{A Codebreaker's Guide to Getting Unstuck}}\par
      \vspace{1.4cm}%
      {\color{ink}\rule{\linewidth}{0.8pt}}\par
      {\color{accent}\rule{\linewidth}{2.5pt}}\par
      \vspace{2.5cm}%
      {\headingfont\color{steel} Crackerjack}\par
      \vspace{0.4cm}%
      \vfill
    \end{center}%
  \end{titlepage}%
}

% ── TOC styling ───────────────────────────────────────────────
\RequirePackage{titletoc}

\titlecontents{chapter}
  [0em]
  {\vspace{0.4em}\headingfont\small\bfseries\color{ink}}
  {}{}
  {\hfill\color{accent}\contentspage}

\titlecontents{section}
  [1.2em]
  {\small\color{steel}}
  {}{}
  {\titlerule*[6pt]{.}\color{muted}\contentspage}

% ── Lists ─────────────────────────────────────────────────────
\RequirePackage{enumitem}
\setlist[itemize]{
  itemsep    = 0.2em,
  topsep     = 0.4em,
  leftmargin = 1.4em,
  label      = {\color{accent}\textbullet}
}
\setlist[enumerate]{
  itemsep    = 0.2em,
  topsep     = 0.4em,
  leftmargin = 1.6em
}

% ── No hyphenation ────────────────────────────────────────────
\RequirePackage[none]{hyphenat}

\endinput